<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.Views.ScanPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#000">

    <Grid RowDefinitions="*,Auto">

        <!-- 🔥 CAMERA CONTAINER -->
        <Grid x:Name="CameraContainer"/>

        <!-- SCAN OVERLAY -->
        <Grid IsVisible="{Binding IsScanning}">
            <BoxView Color="#80000000"/>

            <Frame WidthRequest="260"
                   HeightRequest="260"
                   CornerRadius="16"
                   BackgroundColor="Transparent"
                   BorderColor="#4CAF50"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Label x:Name="ScanTitleLabel"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="0,60,0,0"/>

            <Label x:Name="ScanInstructionLabel"
                   TextColor="White"
                   FontSize="14"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,80"/>
        </Grid>

        <!-- LOADING -->
        <StackLayout IsVisible="{Binding IsLoading}"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
            <ActivityIndicator IsRunning="True" Color="White"/>
            <Label x:Name="LoadingLabel"
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </StackLayout>

        <!-- ERROR -->
        <StackLayout IsVisible="{Binding HasError}"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"
                     Padding="20">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   HorizontalTextAlignment="Center"/>
            <Button x:Name="RetryBtn"
                    Command="{Binding ResetCommand}"/>
        </StackLayout>

        <!-- RESULT -->
        <ScrollView IsVisible="{Binding HasResult}">
            <StackLayout BackgroundColor="White" Padding="20" Spacing="12">

                <Label Text="{Binding CurrentPOI.Name}"
                       FontSize="20"
                       FontAttributes="Bold"/>

                <Label x:Name="TTSSectionLabel"/>
                <Button x:Name="PlayBtn" Command="{Binding PlayCommand}"/>
                <Button x:Name="PauseBtn" Command="{Binding PauseCommand}"/>

                <Label x:Name="ContentSectionLabel"/>
                <Label Text="{Binding CurrentPOI.Content.NarrationText}"/>

                <Button x:Name="ScanAgainBtn"
                        Clicked="OnScanAgainClicked"/>
            </StackLayout>
        </ScrollView>

        <!-- OPEN CAMERA -->
        <Button x:Name="OpenCameraBtn"
                Grid.Row="1"
                Clicked="OnOpenCameraClicked"
                IsVisible="{Binding IsScanning, Converter={StaticResource InvertBoolConverter}}"
                HeightRequest="56"/>
    </Grid>
</ContentPage>