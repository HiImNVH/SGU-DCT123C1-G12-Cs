<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.ProfilePage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- AVATAR -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Frame WidthRequest="100" HeightRequest="100"
                           CornerRadius="50" BackgroundColor="#E0E0E0"
                           HorizontalOptions="Center" Padding="0">
                        <Image x:Name="AvatarImage" Source="user.png"
                               Aspect="AspectFill"/>
                    </Frame>
                    <Label x:Name="FullNameLabel"
                           FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label x:Name="EmailLabel"
                           FontSize="12" TextColor="Gray"
                           HorizontalOptions="Center"/>
                    <Label x:Name="RoleLabel"
                           FontSize="11" TextColor="White"
                           BackgroundColor="#2E7D32"
                           Padding="8,3" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- THÔNG TIN -->
                <Frame CornerRadius="12" Padding="16" BackgroundColor="White">
                    <VerticalStackLayout Spacing="12">

                        <!-- Profile_Title -->
                        <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_Title]}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="#2E7D32"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="12" RowSpacing="10">

                            <!-- Profile_FullName -->
                            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_FullName]}"
                                   FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label x:Name="InfoFullName" Grid.Column="1" VerticalOptions="Center"/>

                            <!-- Profile_Email -->
                            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_Email]}"
                                   Grid.Row="1" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label x:Name="InfoEmail" Grid.Row="1" Grid.Column="1" VerticalOptions="Center"/>

                            <!-- Profile_Language -->
                            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_Language]}"
                                   Grid.Row="2" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label x:Name="InfoLanguage" Grid.Row="2" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- CÀI ĐẶT -->
                <Frame CornerRadius="12" Padding="16" BackgroundColor="White">
                    <VerticalStackLayout Spacing="12">

                        <!-- Profile_Settings -->
                        <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_Settings]}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="#2E7D32"/>

                        <!-- Đổi ngôn ngữ PRO-03 -->
                        <Frame CornerRadius="8" Padding="12" BackgroundColor="#F5F5F5">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangeLanguageClicked"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Text="🌐" FontSize="20" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Padding="10,0">
                                    <!-- Profile_ChangeLanguage -->
                                    <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_ChangeLanguage]}"
                                           FontSize="14" FontAttributes="Bold"/>
                                    <Label x:Name="CurrentLanguageLabel"
                                           FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Label Text="›" Grid.Column="2"
                                       FontSize="20" TextColor="Gray"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <!-- Chỉnh sửa thông tin PRO-02 -->
                        <Frame CornerRadius="8" Padding="12" BackgroundColor="#F5F5F5">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditProfileClicked"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Text="✏️" FontSize="20" VerticalOptions="Center"/>
                                <!-- Profile_EditInfo -->
                                <Label Grid.Column="1"
                                       Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_EditInfo]}"
                                       FontSize="14" FontAttributes="Bold"
                                       Padding="10,0" VerticalOptions="Center"/>
                                <Label Text="›" Grid.Column="2"
                                       FontSize="20" TextColor="Gray"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- ĐĂNG XUẤT -->
                <!-- Profile_Logout -->
                <Button Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Profile_Logout]}"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        CornerRadius="10"
                        Margin="0,8"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
