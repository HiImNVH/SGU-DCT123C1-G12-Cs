<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.Views.ProfilePage"
             Shell.NavBarIsVisible="True"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <StackLayout Spacing="0">

            <!-- Header xanh -->
            <StackLayout BackgroundColor="#2E7D32"
                         Padding="20,40,20,32"
                         HorizontalOptions="Fill">
                <Frame WidthRequest="80"
                       HeightRequest="80"
                       CornerRadius="40"
                       BackgroundColor="#4CAF50"
                       BorderColor="Transparent"
                       Padding="0"
                       HorizontalOptions="Center"
                       Margin="0,0,0,12">
                    <Label Text="👤"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>
                <Label x:Name="UserNameLabel"
                       Text="Du khách"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <Label x:Name="RoleLabel"
                       FontSize="13"
                       TextColor="#C8E6C9"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <!-- Ngôn ngữ -->
            <Frame Margin="16,16,16,0"
                   CornerRadius="14"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="20">
                <StackLayout Spacing="12">
                    <Label x:Name="LanguageSectionLabel"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#555"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackLayout Grid.Column="0">
                            <Label x:Name="LanguageNarrLabel"
                                   FontSize="15"
                                   TextColor="#212121"/>
                            <Label x:Name="CurrentLanguageLabel"
                                   Text="Tiếng Việt"
                                   FontSize="13"
                                   TextColor="#2E7D32"/>
                        </StackLayout>
                        <Button x:Name="ChangeLanguageBtn"
                                Grid.Column="1"
                                Clicked="OnChangeLanguageClicked"
                                BackgroundColor="#E8F5E9"
                                TextColor="#2E7D32"
                                CornerRadius="8"
                                FontSize="13"
                                Padding="16,8"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Thông tin tài khoản -->
            <Frame x:Name="AccountFrame"
                   Margin="16,12,16,0"
                   CornerRadius="14"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="20"
                   IsVisible="False">
                <StackLayout Spacing="12">
                    <Label x:Name="AccountInfoLabel"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#555"/>

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="8">
                        <Label x:Name="UsernameFieldLabel"
                               Grid.Row="0" Grid.Column="0"
                               FontSize="13" TextColor="#888"/>
                        <Label x:Name="InfoUsername"
                               Grid.Row="0" Grid.Column="1"
                               FontSize="14" TextColor="#212121"/>
                        <Label x:Name="RoleFieldLabel"
                               Grid.Row="1" Grid.Column="0"
                               FontSize="13" TextColor="#888"/>
                        <Label x:Name="InfoRole"
                               Grid.Row="1" Grid.Column="1"
                               FontSize="14" TextColor="#212121"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Logout -->
            <Button x:Name="LogoutBtn"
                    Clicked="OnLogoutClicked"
                    Margin="16,16,16,0"
                    BackgroundColor="Transparent"
                    BorderColor="#D32F2F"
                    BorderWidth="1.5"
                    TextColor="#D32F2F"
                    CornerRadius="12"
                    FontSize="14"
                    IsVisible="False"/>

            <!-- Guest frame -->
            <Frame x:Name="GuestFrame"
                   Margin="16,12,16,0"
                   CornerRadius="14"
                   BackgroundColor="#FFF8E1"
                   BorderColor="#FFB300"
                   Padding="16">
                <StackLayout Spacing="8" HorizontalOptions="Center">
                    <Label x:Name="GuestModeLabel"
                           FontSize="14"
                           TextColor="#F57F17"
                           HorizontalOptions="Center"/>
                    <Label x:Name="GuestHintLabel"
                           FontSize="12"
                           TextColor="#888"
                           HorizontalOptions="Center"/>
                    <Button x:Name="LoginPromptBtn"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            CornerRadius="8"
                            FontSize="13"
                            Padding="24,8"/>
                </StackLayout>
            </Frame>

            <BoxView HeightRequest="32"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
