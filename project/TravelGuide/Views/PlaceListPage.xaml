<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.PlaceListPage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- HEADER -->
        <VerticalStackLayout Padding="20">
            <!-- PlaceList_Title -->
            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[PlaceList_Title]}"
                   FontSize="26" FontAttributes="Bold"/>
            <!-- PlaceList_Subtitle -->
            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[PlaceList_Subtitle]}"
                   FontSize="14" TextColor="Gray"/>
        </VerticalStackLayout>

        <!-- SEARCH -->
        <Frame Grid.Row="1" Margin="20,0" Padding="10"
               CornerRadius="12" BackgroundColor="White">
            <Grid ColumnDefinitions="Auto,*">
                <Image Source="search.png" WidthRequest="20"/>
                <!-- PlaceList_SearchPlaceholder -->
                <Entry Grid.Column="1"
                       TextChanged="OnSearchTextChanged"
                       Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[PlaceList_SearchPlaceholder]}"
                       BackgroundColor="Transparent"/>
            </Grid>
        </Frame>

        <!-- LIST -->
        <CollectionView Grid.Row="2" Margin="20,10"
                        ItemsSource="{Binding Places}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="15" Margin="0,0,0,15" Padding="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnItemTapped"/>
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="120,*">
                            <Image Source="{Binding ImageUrl}"
                                   Aspect="AspectFill" HeightRequest="100"/>
                            <VerticalStackLayout Grid.Column="1"
                                                 Padding="10" Spacing="5">
                                <Label Text="{Binding Name}"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Category}"
                                       FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
