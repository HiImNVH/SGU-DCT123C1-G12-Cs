<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.LoginPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <!-- Bind Title vào key Login_Title -->
    <ContentPage.Title>
        <Binding Source="{x:Static svc:LocalizationService.Instance}" Path="[Login_Title]"/>
    </ContentPage.Title>

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <Label Text="🗺️ TravelGuide"
                   FontSize="32" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="#2E7D32"/>

            <!-- Login_Subtitle -->
            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_Subtitle]}"
                   FontSize="14" TextColor="Gray"
                   HorizontalOptions="Center" Margin="0,0,0,16"/>

            <!-- Login_Username -->
            <Entry x:Name="UsernameEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_Username]}"
                   ReturnType="Next"/>

            <!-- Login_Password -->
            <Entry x:Name="PasswordEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_Password]}"
                   IsPassword="True"
                   ReturnType="Done"/>

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False" IsRunning="False"
                               Color="#2E7D32"/>

            <!-- Login_Button -->
            <Button x:Name="LoginBtn"
                    Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_Button]}"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="8"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <!-- Login_NoAccount -->
                <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_NoAccount]}"
                       VerticalOptions="Center"/>
                <!-- Login_SignUp -->
                <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Login_SignUp]}"
                       TextColor="#2E7D32" FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignupClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
