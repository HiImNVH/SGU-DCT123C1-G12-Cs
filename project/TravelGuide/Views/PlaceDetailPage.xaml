<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.PlaceDetailPage"
             Title="{Binding Name}"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Ảnh -->
            <Image Source="{Binding ImageUrl}"
                   HeightRequest="220"
                   Aspect="AspectFill"/>

            <VerticalStackLayout Padding="20" Spacing="12">

                <!-- Tên & Category — giữ nguyên từ dữ liệu POI -->
                <Label Text="{Binding Name}"
                       FontSize="22" FontAttributes="Bold"/>
                <Label Text="{Binding Category}"
                       FontSize="13" TextColor="Gray"/>

                <!-- Thêm vào sau Label Category -->
                <HorizontalStackLayout Spacing="4" Margin="0,4,0,0">
                    <Label Text="⭐" FontSize="16"/>
                    <Label Text="{Binding AverageRating, StringFormat='{0:F1}'}"
           FontSize="16" FontAttributes="Bold" TextColor="#FF8F00"/>
                    <Label Text="{Binding TotalRatings, StringFormat='({0} đánh giá)'}"
           FontSize="13" TextColor="Gray" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Thêm phần đánh giá -->
                <Frame CornerRadius="12" Padding="16" Margin="0,12,0,0"
       BackgroundColor="#F5F5F5">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Đánh giá của bạn"
               FontSize="15" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="8">
                            <Button x:Name="Star1" Text="⭐" BackgroundColor="Transparent"
                    Clicked="OnStarClicked" CommandParameter="1"/>
                            <Button x:Name="Star2" Text="⭐" BackgroundColor="Transparent"
                    Clicked="OnStarClicked" CommandParameter="2"/>
                            <Button x:Name="Star3" Text="⭐" BackgroundColor="Transparent"
                    Clicked="OnStarClicked" CommandParameter="3"/>
                            <Button x:Name="Star4" Text="⭐" BackgroundColor="Transparent"
                    Clicked="OnStarClicked" CommandParameter="4"/>
                            <Button x:Name="Star5" Text="⭐" BackgroundColor="Transparent"
                    Clicked="OnStarClicked" CommandParameter="5"/>
                        </HorizontalStackLayout>
                        <Entry x:Name="CommentEntry" Placeholder="Nhận xét (tuỳ chọn)"/>
                        <Button x:Name="SubmitRatingBtn"
                Text="Gửi đánh giá"
                Clicked="OnSubmitRatingClicked"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="8"/>
                        <Label x:Name="RatingMessage" IsVisible="False"
               TextColor="#2E7D32" FontSize="13"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Mô tả -->
                <Label Text="{Binding Description}"
                       FontSize="15" TextColor="#444"/>

                <!-- Nút TTS -->
                <HorizontalStackLayout Spacing="12" Margin="0,8,0,0">

                    <!-- Detail_Listen -->
                    <Button x:Name="PlayBtn"
                            Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Detail_Listen]}"
                            Clicked="OnPlayNarrationClicked"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            CornerRadius="8"
                            HorizontalOptions="FillAndExpand"/>

                    <!-- Detail_Stop -->
                    <Button x:Name="StopBtn"
                            Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Detail_Stop]}"
                            Clicked="OnStopNarrationClicked"
                            BackgroundColor="#E53935"
                            TextColor="White"
                            CornerRadius="8"
                            IsEnabled="False"
                            WidthRequest="80"/>

                </HorizontalStackLayout>

                <!-- Tọa độ -->
                <Label TextColor="Gray" FontSize="12">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="📍 "/>
                            <Span Text="{Binding Latitude}"/>
                            <Span Text=", "/>
                            <Span Text="{Binding Longitude}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
