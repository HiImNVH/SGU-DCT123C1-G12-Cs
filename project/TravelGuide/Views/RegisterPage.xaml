<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.RegisterPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ContentPage.Title>
        <Binding Source="{x:Static svc:LocalizationService.Instance}" Path="[Register_Title]"/>
    </ContentPage.Title>

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="14">

            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_Title]}"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" Margin="0,16,0,8"/>

            <Entry x:Name="FullNameEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_FullName]}"
                   ReturnType="Next"/>

            <Entry x:Name="UsernameEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_Username]}"
                   ReturnType="Next"/>

            <Entry x:Name="EmailEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_Email]}"
                   Keyboard="Email"
                   ReturnType="Next"/>

            <Entry x:Name="PasswordEntry"
                   Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_Password]}"
                   IsPassword="True"
                   ReturnType="Done"/>

            <Button x:Name="RegisterBtn"
                    Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_Button]}"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="8"/>

            <Button Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Register_BackToLogin]}"
                    Clicked="OnBackToLoginClicked"
                    BackgroundColor="Transparent"
                    TextColor="#2E7D32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
