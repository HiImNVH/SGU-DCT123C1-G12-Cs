<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <ScrollView>
        <StackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo -->
            <Label Text="🗺️"
                   FontSize="64"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>
            <Label Text="Travel Guide"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1B5E20"
                   HorizontalOptions="Center"/>
            <Label x:Name="SubtitleLabel"
                   Text="Tạo tài khoản mới"
                   FontSize="14"
                   TextColor="#888"
                   HorizontalOptions="Center"
                   Margin="0,6,0,32"/>

            <!-- Username -->
            <Label x:Name="UsernameLbl"
                   Text="Tên đăng nhập"
                   FontSize="13"
                   TextColor="#555"
                   Margin="0,0,0,6"/>
            <Frame BackgroundColor="#F8F8F8"
                   CornerRadius="12"
                   BorderColor="#E0E0E0"
                   Padding="16,8"
                   Margin="0,0,0,16">
                <Entry x:Name="UsernameEntry"
                       Placeholder="Nhập tên đăng nhập"
                       PlaceholderColor="#BDBDBD"
                       FontSize="15"
                       ReturnType="Next"/>
            </Frame>

            <!-- Password -->
            <Label x:Name="PasswordLbl"
                   Text="Mật khẩu"
                   FontSize="13"
                   TextColor="#555"
                   Margin="0,0,0,6"/>
            <Frame BackgroundColor="#F8F8F8"
                   CornerRadius="12"
                   BorderColor="#E0E0E0"
                   Padding="16,8"
                   Margin="0,0,0,16">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Ít nhất 6 ký tự"
                       PlaceholderColor="#BDBDBD"
                       IsPassword="True"
                       FontSize="15"
                       ReturnType="Next"/>
            </Frame>

            <!-- Confirm Password -->
            <Label x:Name="ConfirmPasswordLbl"
                   Text="Xác nhận mật khẩu"
                   FontSize="13"
                   TextColor="#555"
                   Margin="0,0,0,6"/>
            <Frame BackgroundColor="#F8F8F8"
                   CornerRadius="12"
                   BorderColor="#E0E0E0"
                   Padding="16,8"
                   Margin="0,0,0,24">
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Nhập lại mật khẩu"
                       PlaceholderColor="#BDBDBD"
                       IsPassword="True"
                       FontSize="15"
                       ReturnType="Done"/>
            </Frame>

            <!-- Register button -->
            <Button x:Name="RegisterBtn"
                    Text="Tạo tài khoản"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="16"
                    HeightRequest="52"
                    Margin="0,0,0,12"/>

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="#2E7D32"
                               Margin="0,0,0,12"/>

            <!-- Separator -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,16">
                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#E0E0E0" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="  hoặc  " TextColor="#BDBDBD" FontSize="13"/>
                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#E0E0E0" VerticalOptions="Center"/>
            </Grid>

            <!-- Back to login -->
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="4">
                <Label x:Name="AlreadyHaveAccountLabel"
                       Text="Đã có tài khoản?"
                       FontSize="14"
                       TextColor="#888"
                       VerticalOptions="Center"/>
                <Button x:Name="BackToLoginBtn"
                        Text="Đăng nhập"
                        Clicked="OnBackToLoginClicked"
                        BackgroundColor="Transparent"
                        TextColor="#2E7D32"
                        FontSize="14"
                        FontAttributes="Bold"
                        Padding="4,0"/>
            </StackLayout>

        </StackLayout>
    </ScrollView>
</ContentPage>
