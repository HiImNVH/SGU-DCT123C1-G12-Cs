<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.Views.MapPage"
             Shell.NavBarIsVisible="True"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*, Auto">

        <!-- ── Bản đồ (chiếm toàn màn hình) ── -->
        <Grid Grid.Row="0">

            <WebView x:Name="mapWeb"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill"/>

            <!-- Loading indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="True"
                               IsRunning="True"
                               Color="#2E7D32"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- Nút định vị lại vị trí người dùng -->
            <Frame HorizontalOptions="End"
                   VerticalOptions="End"
                   Margin="16,0,16,16"
                   WidthRequest="48"
                   HeightRequest="48"
                   CornerRadius="24"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="0"
                   ZIndex="10">
                <ImageButton x:Name="LocateMeBtn"
                             Source="locate_me.png"
                             BackgroundColor="Transparent"
                             Clicked="OnLocateMeClicked"
                             Padding="12"/>
            </Frame>

        </Grid>

        <!-- ── Navigation Panel (hiện khi đang dẫn đường) ── -->
        <Frame x:Name="NavPanel"
               Grid.Row="1"
               IsVisible="False"
               BackgroundColor="White"
               HasShadow="True"
               CornerRadius="0"
               Padding="16,12">

            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">

                <!-- Icon hướng -->
                <Frame Grid.Row="0" Grid.Column="0"
                       WidthRequest="52"
                       HeightRequest="52"
                       CornerRadius="26"
                       BackgroundColor="#E8F5E9"
                       BorderColor="Transparent"
                       Padding="0"
                       VerticalOptions="Center"
                       Margin="0,0,12,0">
                    <Label x:Name="DirectionIcon"
                           Text="▶"
                           FontSize="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="#2E7D32"/>
                </Frame>

                <!-- Thông tin bước hiện tại -->
                <StackLayout Grid.Row="0" Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label x:Name="NavInstructionLabel"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#212121"
                           LineBreakMode="WordWrap"/>
                    <Label x:Name="NavDistanceLabel"
                           FontSize="13"
                           TextColor="#2E7D32"/>
                </StackLayout>

                <!-- Nút dừng dẫn đường -->
                <Button Grid.Row="0" Grid.Column="2"
                        x:Name="StopNavBtn"
                        Text="✕"
                        FontSize="18"
                        BackgroundColor="#FFEBEE"
                        TextColor="#D32F2F"
                        CornerRadius="8"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        VerticalOptions="Center"
                        Margin="8,0,0,0"
                        Clicked="OnStopNavigationClicked"/>

                <!-- Divider -->
                <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                         HeightRequest="1"
                         BackgroundColor="#E0E0E0"
                         Margin="0,10,0,10"/>

                <!-- Tổng hợp: khoảng cách + thời gian còn lại -->
                <StackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             Orientation="Horizontal"
                             Spacing="16">
                    <StackLayout Spacing="2">
                        <Label x:Name="NavTotalDistLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"/>
                        <Label x:Name="NavDistUnitLabel"
                               Text="còn lại"
                               FontSize="12"
                               TextColor="#888"/>
                    </StackLayout>
                    <BoxView WidthRequest="1"
                             BackgroundColor="#E0E0E0"
                             VerticalOptions="Fill"/>
                    <StackLayout Spacing="2">
                        <Label x:Name="NavEtaLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"/>
                        <Label Text="phút"
                               FontSize="12"
                               TextColor="#888"/>
                    </StackLayout>
                    <BoxView WidthRequest="1"
                             BackgroundColor="#E0E0E0"
                             VerticalOptions="Fill"/>
                    <StackLayout Spacing="2">
                        <Label x:Name="NavDestLabel"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2E7D32"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label Text="điểm đến"
                               FontSize="12"
                               TextColor="#888"/>
                    </StackLayout>
                </StackLayout>

                <!-- Nút chế độ đi bộ/xe máy -->
                <StackLayout Grid.Row="2" Grid.Column="2"
                             Orientation="Horizontal"
                             Spacing="4"
                             VerticalOptions="Center">
                    <Button x:Name="WalkModeBtn"
                            Text="🚶"
                            FontSize="18"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="8"
                            Padding="0"
                            BackgroundColor="#E8F5E9"
                            Clicked="OnWalkModeClicked"/>
                    <Button x:Name="BikeModeBtn"
                            Text="🛵"
                            FontSize="18"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="8"
                            Padding="0"
                            BackgroundColor="#F5F5F5"
                            Clicked="OnBikeModeClicked"/>
                </StackLayout>

            </Grid>
        </Frame>

    </Grid>
</ContentPage>
