<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.Views.POIDetailPage"
             Shell.NavBarIsVisible="True"
             BackgroundColor="#F5F5F5">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding BackCommand}"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <StackLayout Spacing="0">

                <!-- Ảnh POI -->
                <Grid HeightRequest="240">
                    <Image x:Name="POIImage"
                           Source="{Binding POI.ImageUrl}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"/>
                    <BoxView Color="#30000000"/>

                    <Frame HorizontalOptions="Start"
                           VerticalOptions="Start"
                           Margin="16,16,0,0"
                           BackgroundColor="#CC2E7D32"
                           CornerRadius="8"
                           Padding="10,4">
                        <Label Text="{Binding POI.Category}"
                               TextColor="White"
                               FontSize="12"
                               FontAttributes="Bold"/>
                    </Frame>
                </Grid>

                <!-- Card chính -->
                <Frame Margin="16,-24,16,0"
                       CornerRadius="18"
                       BackgroundColor="White"
                       HasShadow="True"
                       Padding="20">
                    <StackLayout Spacing="16">

                        <!-- Tên POI -->
                        <Label Text="{Binding POI.Name}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1B5E20"/>

                        <!-- Loading -->
                        <ActivityIndicator IsVisible="{Binding IsLoading}"
                                           IsRunning="{Binding IsLoading}"
                                           Color="#2E7D32"/>

                        <!-- TTS Section -->
                        <StackLayout IsVisible="{Binding HasContent}" Spacing="12">
                            <BoxView HeightRequest="1" Color="#E0E0E0"/>

                            <Label x:Name="TTSSectionLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#555"/>

                            <!-- TTS Controls -->
                            <Grid ColumnDefinitions="*,56,56" ColumnSpacing="8">
                                <Button x:Name="PlayBtn"
                                        Grid.Column="0"
                                        Command="{Binding PlayCommand}"
                                        IsVisible="{Binding CanPlay}"
                                        BackgroundColor="#2E7D32"
                                        TextColor="White"
                                        CornerRadius="10"
                                        FontSize="14"
                                        HeightRequest="48"/>

                                <Button x:Name="PauseBtn"
                                        Grid.Column="0"
                                        Command="{Binding PauseCommand}"
                                        IsVisible="{Binding IsPlaying}"
                                        BackgroundColor="#F57C00"
                                        TextColor="White"
                                        CornerRadius="10"
                                        FontSize="14"
                                        HeightRequest="48"/>

                                <Button x:Name="ResumeBtn"
                                        Grid.Column="0"
                                        Command="{Binding ResumeCommand}"
                                        IsVisible="{Binding IsPaused}"
                                        BackgroundColor="#1976D2"
                                        TextColor="White"
                                        CornerRadius="10"
                                        FontSize="14"
                                        HeightRequest="48"/>

                                <Button x:Name="StopBtn"
                                        Grid.Column="1"
                                        Text="⏹"
                                        Command="{Binding StopCommand}"
                                        BackgroundColor="#EEEEEE"
                                        TextColor="#333"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        FontSize="18"/>

                                <Frame Grid.Column="2"
                                       BackgroundColor="#E8F5E9"
                                       CornerRadius="10"
                                       Padding="0"
                                       HeightRequest="48">
                                    <Label Text="{Binding LanguageFlag}"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                            </Grid>

                            <!-- Playing badge -->
                            <Frame x:Name="PlayingBadge"
                                   BackgroundColor="#F1F8E9"
                                   CornerRadius="8"
                                   Padding="10,6"
                                   IsVisible="{Binding IsPlaying}">
                                <Label x:Name="PlayingLabel"
                                       TextColor="#388E3C"
                                       FontSize="13"/>
                            </Frame>

                            <BoxView HeightRequest="1" Color="#E0E0E0"/>

                            <!-- Nội dung văn bản -->
                            <Label x:Name="ContentLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#555"/>

                            <Label Text="{Binding NarrationText}"
                                   FontSize="15"
                                   TextColor="#333"
                                   LineBreakMode="WordWrap"
                                   LineHeight="1.5"/>
                        </StackLayout>

                        <!-- No content state -->
                        <StackLayout IsVisible="{Binding HasNoContent}" Spacing="8">
                            <Label x:Name="NoContentLabel"
                                   FontSize="14"
                                   TextColor="#888"
                                   HorizontalOptions="Center"/>
                        </StackLayout>

                    </StackLayout>
                </Frame>

                <BoxView HeightRequest="32"/>
            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
