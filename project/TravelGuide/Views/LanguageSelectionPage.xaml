<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.LanguageSelectionPage"
             BackgroundColor="White"
               Shell.NavBarIsVisible="False">

    <ContentPage.Title>
        <Binding Source="{x:Static svc:LocalizationService.Instance}" Path="[Lang_Title]"/>
    </ContentPage.Title>

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

        <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Lang_Select]}"
               FontSize="20" FontAttributes="Bold"
               HorizontalOptions="Center" Margin="0,0,0,16"/>

        <CollectionView ItemsSource="{Binding Languages}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4" Padding="16"
                            BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8">
                        <Button Text="{Binding NativeName}"
                                CommandParameter="{Binding Code}"
                                Clicked="OnLanguageSelected"
                                BackgroundColor="Transparent"
                                TextColor="#2E7D32"
                                FontSize="16"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
