<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:svc="clr-namespace:TravelGuide.Services"
             x:Class="TravelGuide.HomePage"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- HEADER -->
        <Grid Padding="20" ColumnDefinitions="*,Auto">
            <VerticalStackLayout>
                <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Home_Welcome]}"
                       FontSize="26" FontAttributes="Bold"/>
                <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Home_Subtitle]}"
                       FontSize="14" TextColor="Gray"/>
            </VerticalStackLayout>
        </Grid>

        <!-- SEARCH BAR -->
        <Frame Grid.Row="1" Margin="20,0" Padding="10"
               CornerRadius="12" BackgroundColor="White">
            <Grid ColumnDefinitions="Auto,*">
                <Image Source="search.png" WidthRequest="20" HeightRequest="20"/>
                <Entry Grid.Column="1"
                       Placeholder="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Home_SearchPlaceholder]}"
                       BackgroundColor="Transparent"/>
            </Grid>
        </Frame>

        <!-- LOCATION LIST -->
        <VerticalStackLayout Grid.Row="2" Padding="20">
            <Label Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=[Home_Nearby]}"
                   FontSize="22" FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding NearbyPlaces}"
                            HeightRequest="220" Margin="0,15,0,0">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame WidthRequest="180" HeightRequest="200"
                               CornerRadius="15" Padding="0" Margin="0,0,15,0">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnItemTapped"/>
                            </Frame.GestureRecognizers>
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                <Grid VerticalOptions="End" Padding="10"
                                      BackgroundColor="#66000000">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}"
                                               TextColor="White"
                                               FontSize="16" FontAttributes="Bold"/>
                                        <Label Text="{Binding Category}"
                                               TextColor="White" FontSize="12"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- MAP BUTTON -->
        <ImageButton Source="map.png"
                     WidthRequest="48" HeightRequest="48"
                     CornerRadius="38" BackgroundColor="White"
                     Grid.RowSpan="3"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="20" Clicked="OnMapClicked">
            <ImageButton.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Offset="0,4" Radius="10"/>
            </ImageButton.Shadow>
        </ImageButton>

    </Grid>
</ContentPage>