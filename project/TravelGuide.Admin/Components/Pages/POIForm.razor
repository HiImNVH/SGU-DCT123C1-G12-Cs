@page "/poi/add"
@page "/poi/edit/{Id:guid}"
@rendermode InteractiveServer
@inject IAdminApiService ApiService
@inject ITranslationService Translator
@inject NavigationManager Nav

<div class="form-container">
    <h2>@(Id == Guid.Empty ? "➕ Thêm POI mới" : "✏️ Sửa POI")</h2>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="@(_success ? "alert-success" : "alert-error")">@_message</div>
    }

    <div class="form-grid">
        <div class="form-group">
            <label>Tên địa điểm *</label>
            <input @bind="_form.Name" placeholder="VD: Chợ Bến Thành"/>
        </div>
        <div class="form-group">
            <label>Danh mục *</label>
            <select @bind="_form.Category">
                <option value="">-- Chọn --</option>
                <option value="Chợ">Chợ</option>
                <option value="Di tích">Di tích</option>
                <option value="Tòa nhà">Tòa nhà</option>
                <option value="Khu vui chơi">Khu vui chơi</option>
                <option value="Bảo tàng">Bảo tàng</option>
                <option value="Công viên">Công viên</option>
            </select>
        </div>
        <div class="form-group">
            <label>Vĩ độ (Latitude) *</label>
            <input type="number" step="0.000001" @bind="_form.Latitude"/>
        </div>
        <div class="form-group">
            <label>Kinh độ (Longitude) *</label>
            <input type="number" step="0.000001" @bind="_form.Longitude"/>
        </div>
        <div class="form-group">
            <label>Bán kính (mét)</label>
            <input type="number" @bind="_form.Radius"/>
        </div>
        <div class="form-group">
            <label>URL hình ảnh</label>
            <input @bind="_form.ImageUrl" placeholder="https://..."/>
        </div>
        <div class="form-group full-width">
            <label>Mô tả</label>
            <textarea @bind="_form.Description" rows="3"></textarea>
        </div>
    </div>

    <!-- Chỉ nhập tiếng Việt -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:24px;">
        <h3>🇻🇳 Nội dung thuyết minh tiếng Việt</h3>
        <button class="btn-translate" @onclick="TranslateAll" disabled="@_translating">
            @(_translating ? "⏳ Đang dịch..." : "🌐 Tự động dịch sang các ngôn ngữ khác")
        </button>
    </div>

    @{
        var vi = GetOrCreateContent("vi");
    }
    <div class="lang-block">
        <div class="form-group">
            <label>Tiêu đề (tiếng Việt)</label>
            <input @bind="vi.Title" placeholder="VD: Chợ Bến Thành - Biểu tượng Sài Gòn"/>
        </div>
        <div class="form-group">
            <label>Nội dung thuyết minh (tiếng Việt) *</label>
            <textarea @bind="vi.NarrationText" rows="5"
                      placeholder="Nhập nội dung thuyết minh tiếng Việt tại đây. Hệ thống sẽ tự động dịch sang các ngôn ngữ khác khi bạn nhấn nút dịch."></textarea>
        </div>
    </div>

    <!-- Hiển thị kết quả dịch -->
    @if (_translatedLanguages.Any())
    {
        <h3 style="margin-top:20px">🌍 Nội dung đã dịch</h3>
        @foreach (var lang in _otherLanguages)
        {
            var content = _form.Contents.FirstOrDefault(c => c.LanguageCode == lang.Code);
            @if (content != null && !string.IsNullOrEmpty(content.NarrationText))
            {
                <div class="lang-block translated">
                    <div class="lang-header">@lang.Flag @lang.Name (@lang.Code)</div>
                    <div class="form-group">
                        <label>Tiêu đề</label>
                        <input @bind="content.Title"/>
                    </div>
                    <div class="form-group">
                        <label>Nội dung (có thể chỉnh sửa)</label>
                        <textarea @bind="content.NarrationText" rows="4"></textarea>
                    </div>
                </div>
            }
        }
    }

    <div class="form-actions">
        <button class="btn-cancel" @onclick='() => Nav.NavigateTo("/")'>Hủy</button>
        <button class="btn-save" @onclick="HandleSave" disabled="@_saving">
            @(_saving ? "Đang lưu..." : "💾 Lưu")
        </button>
    </div>
</div>

<style>
    .form-container { max-width:900px; margin:0 auto; padding:20px; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; background:white; padding:20px; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group.full-width { grid-column:1/-1; }
    .form-group label { font-weight:600; font-size:13px; color:#333; }
    .form-group input, .form-group select, .form-group textarea {
        padding:10px; border:1px solid #ddd; border-radius:8px; font-size:14px; font-family:inherit;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
        outline:none; border-color:#2E7D32;
    }
    .lang-block { background:white; border-radius:12px; padding:16px; margin-top:12px; box-shadow:0 1px 4px rgba(0,0,0,0.08); }
    .lang-block.translated { border-left:4px solid #2E7D32; }
    .lang-header { font-weight:700; font-size:15px; margin-bottom:12px; color:#2E7D32; }
    .form-actions { display:flex; gap:12px; justify-content:flex-end; margin-top:24px; }
    .btn-save { background:#2E7D32; color:white; border:none; padding:12px 28px; border-radius:8px; cursor:pointer; font-size:15px; font-weight:600; }
    .btn-save:hover:not(:disabled) { background:#1B5E20; }
    .btn-save:disabled { background:#A5D6A7; cursor:not-allowed; }
    .btn-cancel { background:#9E9E9E; color:white; border:none; padding:12px 28px; border-radius:8px; cursor:pointer; font-size:15px; }
    .btn-cancel:hover { background:#757575; }
    .btn-translate { background:#1976D2; color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-size:13px; }
    .btn-translate:hover:not(:disabled) { background:#1565C0; }
    .btn-translate:disabled { background:#90CAF9; cursor:not-allowed; }
    .alert-success { background:#E8F5E9; color:#2E7D32; padding:12px; border-radius:8px; margin-bottom:16px; }
    .alert-error { background:#FFEBEE; color:#C62828; padding:12px; border-radius:8px; margin-bottom:16px; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private CreatePOIRequest _form = new() { Radius = 50 };
    private string _message = "";
    private bool _success = false;
    private bool _saving = false;
    private bool _translating = false;
    private HashSet<string> _translatedLanguages = new();

    private record LangInfo(string Code, string Name, string Flag);

    private List<LangInfo> _otherLanguages = new()
    {
        new("en", "English", "🇬🇧"),
        new("ja", "日本語", "🇯🇵"),
        new("ko", "한국어", "🇰🇷"),
        new("zh", "中文", "🇨🇳"),
        new("fr", "Français", "🇫🇷")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        
        await ApiService.InitializeAsync();

        if (!ApiService.IsLoggedIn())
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        if (Id != Guid.Empty)
        {
            var poi = await ApiService.GetPOIAsync(Id);
            if (poi != null)
            {
                _form = new CreatePOIRequest
                {
                    Name = poi.Name,
                    Description = poi.Description ?? "",
                    Latitude = poi.Latitude,
                    Longitude = poi.Longitude,
                    Radius = poi.Radius,
                    ImageUrl = poi.ImageUrl ?? "",
                    Category = poi.Category,
                    Contents = poi.Contents.ToList()
                };

                // Đánh dấu các ngôn ngữ đã có
                foreach (var c in _form.Contents.Where(c => c.LanguageCode != "vi"))
                {
                    _translatedLanguages.Add(c.LanguageCode);
                }

                StateHasChanged();
            }
        }
    }

    private POIContentDto GetOrCreateContent(string langCode)
    {
        var content = _form.Contents.FirstOrDefault(c => c.LanguageCode == langCode);
        if (content == null)
        {
            content = new POIContentDto { LanguageCode = langCode };
            _form.Contents.Add(content);
        }
        return content;
    }

    private async Task TranslateAll()
    {
        var vi = GetOrCreateContent("vi");
        if (string.IsNullOrWhiteSpace(vi.NarrationText))
        {
            _message = "⚠️ Vui lòng nhập nội dung tiếng Việt trước khi dịch!";
            _success = false;
            return;
        }

        _translating = true;
        _message = "";
        StateHasChanged();

        int successCount = 0;

        foreach (var lang in _otherLanguages)
        {
            try
            {
                // Dịch tiêu đề nếu có
                if (!string.IsNullOrWhiteSpace(vi.Title))
                {
                    var translatedTitle = await Translator.TranslateAsync(vi.Title, "vi", lang.Code);
                    if (!string.IsNullOrEmpty(translatedTitle))
                    {
                        var content = GetOrCreateContent(lang.Code);
                        content.Title = translatedTitle;
                    }
                }

                // Dịch nội dung
                var translatedText = await Translator.TranslateAsync(vi.NarrationText, "vi", lang.Code);

                if (!string.IsNullOrEmpty(translatedText))
                {
                    var content = GetOrCreateContent(lang.Code);
                    content.NarrationText = translatedText;
                    _translatedLanguages.Add(lang.Code);
                    successCount++;
                }

                // Delay nhỏ để tránh rate limit
                await Task.Delay(200);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Translation failed for {lang.Code}: {ex.Message}");
            }
        }

        _translating = false;
        _message = successCount > 0
            ? $"✅ Đã dịch thành công sang {successCount}/{_otherLanguages.Count} ngôn ngữ!"
            : "❌ Không thể dịch tự động. Vui lòng kiểm tra kết nối mạng.";
        _success = successCount > 0;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.Category))
        {
            _message = "⚠️ Vui lòng nhập đầy đủ tên địa điểm và danh mục!";
            _success = false;
            return;
        }

        var vi = _form.Contents.FirstOrDefault(c => c.LanguageCode == "vi");
        if (vi == null || string.IsNullOrWhiteSpace(vi.NarrationText))
        {
            _message = "⚠️ Vui lòng nhập nội dung thuyết minh tiếng Việt!";
            _success = false;
            return;
        }

        _saving = true;
        StateHasChanged();

        // Chỉ lưu content có nội dung
        _form.Contents = _form.Contents
            .Where(c => !string.IsNullOrWhiteSpace(c.NarrationText))
            .ToList();

        bool success = Id == Guid.Empty
            ? await ApiService.CreatePOIAsync(_form)
            : await ApiService.UpdatePOIAsync(Id, _form);

        _saving = false;
        _success = success;
        _message = success
            ? "✅ Lưu địa điểm thành công!"
            : "❌ Lưu thất bại. Vui lòng kiểm tra lại thông tin và thử lại.";

        StateHasChanged();

        if (success)
        {
            await Task.Delay(1500);
            Nav.NavigateTo("/", true);
        }
    }
}