@page "/users"
@rendermode InteractiveServer
@inject IAdminApiService ApiService
@inject NavigationManager Nav

<div class="page-header">
    <h2>👥 Quản lý người dùng</h2>
</div>

@if (_loading)
{
    <div class="loading">⏳ Đang tải danh sách...</div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Tên đăng nhập</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Ngôn ngữ</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr>
                    <td><b>@user.Username</b></td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="@(user.Role == "Admin" ? "badge-admin" : "badge-user")">
                            @(user.Role == "Admin" ? "Quản trị viên" : "Du khách")
                        </span>
                    </td>
                    <td>@user.PreferredLanguage</td>
                    <td>
                        <span class="@(user.IsActive ? "status-active" : "status-inactive")">
                            @(user.IsActive ? "Hoạt động" : "Bị khóa")
                        </span>
                    </td>
                    <td>
                        <button class="@(user.IsActive ? "btn-lock" : "btn-unlock")"
                                @onclick="@(() => ToggleUser(user))">
                            @(user.IsActive ? "🔒 Khóa" : "🔓 Mở khóa")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert-error">@_error</div>
}

<style>
    .page-header { margin-bottom:20px; }
    .data-table { width:100%; border-collapse:collapse; background:white; border-radius:12px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.08); }
    .data-table th { background:#2E7D32; color:white; padding:12px 16px; text-align:left; font-size:13px; }
    .data-table td { padding:12px 16px; border-bottom:1px solid #f0f0f0; font-size:13px; }
    .data-table tr:hover { background:#f9f9f9; }
    .badge-admin { background:#FFF3E0; color:#E65100; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; }
    .badge-user { background:#E8F5E9; color:#2E7D32; padding:3px 10px; border-radius:20px; font-size:12px; }
    .status-active { color:#2E7D32; font-weight:600; }
    .status-inactive { color:#E53935; font-weight:600; }
    .btn-lock { background:#FF7043; color:white; border:none; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-lock:hover { background:#F4511E; }
    .btn-unlock { background:#2E7D32; color:white; border:none; padding:5px 12px; border-radius:6px; cursor:pointer; font-size:12px; }
    .btn-unlock:hover { background:#1B5E20; }
    .loading { text-align:center; padding:40px; color:gray; }
    .alert-error { background:#FFEBEE; color:#C62828; padding:12px; border-radius:8px; margin-top:16px; }
</style>

@code {
    private List<UserDto> _users = new();
    private bool _loading = true;
    private string _error = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        
        await ApiService.InitializeAsync();

        if (!ApiService.IsLoggedIn())
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        try
        {
            _users = await ApiService.GetUsersAsync();
        }
        catch (Exception ex)
        {
            _error = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        StateHasChanged();
    }

    private async Task ToggleUser(UserDto user)
    {
        var success = await ApiService.ToggleUserActiveAsync(user.Id);
        if (success)
        {
            user.IsActive = !user.IsActive;
            StateHasChanged();
        }
        else
        {
            _error = $"Không thể thay đổi trạng thái tài khoản '{user.Username}'. Vui lòng thử lại.";
            StateHasChanged();
        }
    }
}