<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.RegisterPage"
             BackgroundColor="#F5F5F5">

    <ScrollView>

        <VerticalStackLayout Padding="30" Spacing="18">

            <!-- Title -->
            <Label
                Text="Create Account"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Label
                Text="Join Travel Guide today"
                FontSize="16"
                TextColor="Gray"
                HorizontalOptions="Center"/>

            <!-- Full Name -->
            <Entry
                x:Name="NameEntry"
                Placeholder="Full Name"
                BackgroundColor="White"
                HeightRequest="50"/>

            <!-- Email -->
            <Entry
                x:Name="EmailEntry"
                Placeholder="Email"
                Keyboard="Email"
                BackgroundColor="White"
                HeightRequest="50"/>

            <!-- Phone -->
            <Entry
                x:Name="PhoneEntry"
                Placeholder="Phone Number"
                Keyboard="Telephone"
                BackgroundColor="White"
                HeightRequest="50"/>

            <!-- Password -->
            <Entry
                x:Name="PasswordEntry"
                Placeholder="Password"
                IsPassword="True"
                BackgroundColor="White"
                HeightRequest="50"/>

            <!-- Confirm Password -->
            <Entry
                x:Name="ConfirmPasswordEntry"
                Placeholder="Confirm Password"
                IsPassword="True"
                BackgroundColor="White"
                HeightRequest="50"/>

            <!-- Register Button -->
            <Button
                Text="Register"
                BackgroundColor="#4CAF50"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="50"
                CornerRadius="10"
                Clicked="OnRegisterClicked"/>

            <!-- Back to login -->
            <Button
                Text="Already have an account? Login"
                BackgroundColor="Transparent"
                TextColor="#2196F3"
                Clicked="OnBackToLoginClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>