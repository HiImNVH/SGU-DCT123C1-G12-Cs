<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TravelGuide.PlaceListPage"
    BackgroundColor="#F2F2F2"
    Title="Địa điểm">
    <Grid RowDefinitions="*,Auto">

        <!-- MAIN CONTENT -->
        <VerticalStackLayout Padding="16" Spacing="10">

            <Label 
                Text="Khám phá địa điểm"
                FontSize="24"
                FontAttributes="Bold"/>

            <Frame CornerRadius="12" Padding="10" BackgroundColor="#F2F2F2">
                <HorizontalStackLayout>
                    <Image Source="search.png" WidthRequest="20"/>
                    <Entry Placeholder="Tìm địa điểm..." />
                </HorizontalStackLayout>
            </Frame>

            <CollectionView x:Name="PlaceList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame 
                            CornerRadius="16"
                            Margin="0,5"
                            HasShadow="True"
                            Padding="0">

                            <Grid RowDefinitions="150,Auto">

                                <Image 
                                    Source="{Binding Image}"
                                    Aspect="AspectFill"/>

                                <VerticalStackLayout 
                                    Grid.Row="1"
                                    Padding="10">

                                    <Label 
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontAttributes="Bold"/>

                                    <Label 
                                        Text="{Binding Description}"
                                        FontSize="13"
                                        TextColor="Gray"/>

                                </VerticalStackLayout>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <!-- BOTTOM MENU -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="10"
              ColumnDefinitions="*,*,*">

            <VerticalStackLayout HorizontalOptions="Center">
                <Image Source="home.png" WidthRequest="25"/>
                <Label Text="Trang chủ" FontSize="12"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="HomePageTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Image Source="location.png" WidthRequest="25"/>
                <Label Text="Địa điểm" FontSize="12"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnUserTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="user.png" WidthRequest="25"/>
                <Label Text="Cá nhân" FontSize="12"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>